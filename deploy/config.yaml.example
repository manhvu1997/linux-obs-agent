# ──────────────────────────────────────────────────────────────────────────────
# obs-agent configuration  (all values shown are production defaults)
# ──────────────────────────────────────────────────────────────────────────────

agent:
  log_level: info          # debug | info | warn | error
  metrics_addr: ":9200"    # Prometheus scrape endpoint (empty = disabled)
  node_name: ""            # override auto-detected hostname (useful in containers)

# ─── Baseline /proc collectors ────────────────────────────────────────────────
collect:
  interval: 5s
  # Disk devices to monitor (empty = all non-partition block devices)
  disk_devices: []
  # Network interfaces to monitor (empty = all non-loopback)
  net_interfaces: []

# ─── eBPF on-demand modules ───────────────────────────────────────────────────
ebpf:
  enabled: true
  # How long each eBPF module stays active after being triggered.
  active_duration: 60s
  # Minimum time before the same module can be re-triggered.
  cool_down: 120s
  # IO latency events below this threshold are suppressed (reduces noise).
  slow_io_threshold_us: 10000    # 1 ms
  # Run-queue latency events below this threshold are suppressed.
  runqlat_threshold_us: 50000    # 5 ms
  # CPU profiling sample frequency (perf_event Hz).
  # Lower = less overhead.  99 Hz ≈ 0.1% CPU on a modern server.
  sample_hz: 99

# ─── Trigger rules ────────────────────────────────────────────────────────────
trigger:
  # Activate cpu_profile when total CPU usage exceeds this.
  cpu_usage_percent: 85.0
  # Activate io_latency when iowait% exceeds this.
  iowait_percent: 20.0
  # Activate runqlat (and io_latency) when load/cpu > this AND cpu < 50%.
  # Example: 16-CPU machine with load 24 → norm_load = 1.5 → trigger fires.
  load_normalised: 1.5
  # Activate runqlat when context switches per second exceed this.
  ctx_switch_delta: 100000
  # Activate tcp_retransmit when network errors per second exceed this.
  net_error_delta: 100
  # How often the trigger engine evaluates these rules.
  eval_interval: 10s

# ─── Process inspection ───────────────────────────────────────────────────────
process:
  # Number of top processes to include in each snapshot.
  top_n: 20
  # How often to rescan /proc for process stats.
  scan_interval: 10s
  # Include per-process IO stats (may need CAP_SYS_PTRACE).
  include_io: true

# ─── HTTP exporter (send to central server) ───────────────────────────────────
exporter:
  # Central server endpoint (empty = disabled; only Prometheus endpoint is used).
  url: ""           # e.g. "https://collector.internal:8080"
  batch_size: 200   # max eBPF events per HTTP POST
  flush_interval: 30s
  compress: true    # gzip payloads
  timeout: 10s

# ─── Fsync latency tracer (always-on, bounded LRU map) ───────────────────────
# Traces fsync / fdatasync / sync_file_range via kprobe/kretprobe.
# Aggregates per-PID call counts and latency in-kernel; userspace polls every
# poll_interval.  The analysis snapshot is published to GET /api/diagnose ONLY
# when the system is under pressure (cpu_threshold OR mem_threshold breached).
fsync:
  # Master switch.  Set to false to skip loading the kprobes entirely.
  enabled: true

  # Emit a ringbuf outlier event only when a single fsync call exceeds this
  # latency.  Normal-speed calls still update the in-kernel LRU map (no wakeup).
  # Default 5 000 µs = 5 ms.  Lower → more events, higher CPU from ringbuf drain.
  slow_threshold_us: 1000

  # How often the Go analyzer batch-reads the in-kernel LRU map and re-evaluates
  # top offenders.  Must be a valid Go duration string (e.g. "5s", "10s").
  # NOTE: bare integers like "5" are parsed as nanoseconds — always add the unit.
  poll_interval: 5s

  # Max number of top offenders included in the FsyncAnalysis report.
  # Each entry is enriched with /proc cmdline, cgroup path, and app-type label.
  top_n: 20

  # Ignore LRU map entries whose last_seen timestamp is older than this many
  # seconds.  Prevents reporting processes that have already exited.
  stale_seconds: 60

  # Publish a new FsyncAnalysis snapshot when CPU usage exceeds this percent.
  # Set to 101 to disable CPU-based publishing (use mem_threshold only).
  cpu_threshold: 85.0

  # Publish a new FsyncAnalysis snapshot when memory usage exceeds this percent.
  # Your prod-mongodb-noti server runs at ~90% memory — this threshold fires.
  mem_threshold: 85.0

# ─── Memory writeback / direct-reclaim tracer (always-on, bounded LRU map) ───
# Traces dirty page generation per PID (writeback_dirty_page tracepoint) and
# direct-reclaim stall latency per PID (mm_vmscan_direct_reclaim_begin/end).
# Unlike kswapd (background reclaim), direct reclaim stalls the application
# thread directly — tracking it reveals which processes are causing memory
# pressure.  The analysis snapshot is published to GET /api/diagnose ONLY
# when the system is under pressure (mem_threshold breached OR any PID's
# max direct-reclaim stall exceeds reclaim_spike_ns).
writeback:
  # Master switch.  Set to false to skip loading the tracepoints entirely.
  enabled: true

  # Emit a ringbuf outlier event only when a single direct-reclaim episode
  # exceeds this latency (nanoseconds).  Normal stalls still update the
  # in-kernel LRU map (no wakeup).
  # Default 100 000 000 ns = 100 ms.
  slow_reclaim_threshold_ns: 100000000

  # How often the Go analyzer batch-reads the in-kernel LRU map.
  # NOTE: bare integers like "5" are parsed as nanoseconds — always add the unit.
  poll_interval: 5s

  # Max number of top offenders included in the WritebackAnalysis report.
  # Each entry is enriched with /proc cmdline, cgroup path, and app-type label.
  top_n: 20

  # Ignore LRU map entries whose last_seen timestamp is older than this many
  # seconds.  Prevents reporting processes that have already exited.
  stale_seconds: 60

  # Publish a new WritebackAnalysis snapshot when memory usage exceeds this %.
  mem_threshold: 85.0

  # Publish a new WritebackAnalysis snapshot when any PID's max direct-reclaim
  # stall exceeds this threshold (nanoseconds).
  # Default 10 000 000 ns = 10 ms — catches serious memory pressure spikes.
  # Set to 0 to disable reclaim-spike-based publishing (use mem_threshold only).
  reclaim_spike_ns: 10000000
